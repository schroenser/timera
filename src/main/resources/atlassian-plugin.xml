<?xml version="1.0" encoding="UTF-8"?>
<atlassian-plugin name="${project.name}" key="${atlassian.plugin.key}" plugins-version="2">

    <plugin-info>
        <description>${project.description}</description>
        <param name="plugin-icon">images/timera.png</param>
        <param name="plugin-logo">images/timera.png</param>
        <vendor name="${project.organization.name}" url="${project.organization.url}" />
        <version>${project.version}</version>
    </plugin-info>

    <!-- add our i18n resource -->
    <resource name="i18n" location="timera" type="i18n" />

    <web-item name="timera-page-item" key="timera-page-item" section="system.top.navigation.bar" weight="1000">
        <label key="timera-page-item.label" />
        <link linkId="timera-page-item-link">/projects/${pathEncodedProjectKey}?selectedItem=${atlassian.plugin.key}:timera-page</link>
    </web-item>

    <web-panel name="timera-page" key="timera-page" location="${atlassian.plugin.key}:timera-page" weight="1000">
        <resource name="view" type="velocity" location="templates/timera.vm" />
    </web-panel>

</atlassian-plugin>
